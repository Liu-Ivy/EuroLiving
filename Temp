<!-- 請將以下 CSS 加入到原有的 <style> 標籤中 -->
<style>
    .expand-btn {
        background: none;
        border: 1px solid var(--main-gold);
        color: var(--main-gold);
        padding: 8px 20px;
        border-radius: 20px;
        cursor: pointer;
        font-weight: 600;
        margin-top: 15px;
        transition: 0.3s;
        font-size: 0.9rem;
    }
    
    .expand-btn:hover {
        background: var(--main-gold);
        color: white;
    }

    .details-content {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.5s ease-out;
        border-top: 0px solid #eee;
    }

    .details-content.active {
        max-height: 300px; /* 預期展開的最大高度 */
        margin-top: 10px;
        border-top: 1px solid #eee;
    }

    .expand-btn i {
        transition: transform 0.3s;
    }

    .expand-btn.active i {
        transform: rotate(180deg);
    }
</style>

<!-- 請將以下 JavaScript 加入到原有的 <script> 標籤中 -->
<script>
    function toggleDetails(btn) {
        const content = btn.nextElementSibling;
        
        // 切換內容的 active class
        content.classList.toggle('active');
        
        // 切換按鈕本身的 active class (旋轉圖示)
        btn.classList.toggle('active');
        
        // 修改按鈕文字
        if (content.classList.contains('active')) {
            btn.innerHTML = '收起細節 <i class="fas fa-chevron-down"></i>';
        } else {
            btn.innerHTML = '展開需求細節 <i class="fas fa-chevron-down"></i>';
        }
    }
</script>
