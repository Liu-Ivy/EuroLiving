<style>
    /* 修正 1: 讓標題下劃線更優雅，增加間距 */
    .section-title h2 { 
        font-size: 2.2rem; 
        position: relative; 
        display: inline-block; 
        padding-bottom: 25px; /* 增加文字與線的距離 */
        margin-bottom: 20px;
    }
    .section-title h2::after { 
        content: ''; 
        width: 60px; 
        height: 3px; 
        background: var(--main-gold); 
        position: absolute; 
        bottom: 0; 
        left: 50%; 
        transform: translateX(-50%); 
    }

    /* 修正 2: 專業服務內容的 2x2 佈局優化 */
    .services-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr); /* 強制兩兩一排 */
        gap: 30px;
    }

    /* 手機版自動切換回一排 */
    @media (max-width: 768px) {
        .services-grid {
            grid-template-columns: 1fr;
        }
    }

    /* 統一卡片圖片比例 */
    .card-img {
        position: relative;
        width: 100%;
        height: 240px;
        background-size: cover;
        background-position: center;
    }
</style>

<!-- 適合這樣的您 -->
<section class="section-light" id="target-audience">
    <div class="container">
        <div class="section-title">
            <h2>適合這樣的您</h2>
            <p style="color: var(--text-muted); margin-top: 10px; margin-bottom: 60px;">量身打造的在地支援方案</p>
        </div>
        
        <div class="grid">
            <!-- 1. 華人家庭 -->
            <div class="card">
                <div class="card-img" style="background-image: url('https://images.unsplash.com/photo-1543269865-cbf427effbad?q=80&w=600')"></div>
                <div class="card-content">
